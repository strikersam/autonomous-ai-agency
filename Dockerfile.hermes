# Dockerfile.hermes — the agency's OWN Hermes runtime server.
#
# Runs services/hermes_server.py (FastAPI) which speaks the API the
# HermesAdapter calls and executes via InternalAgentAdapter (our brain).
# Lightweight: no Playwright/Chromium (Hermes delegates LLM work to the brain).
FROM python:3.13-slim

# git is needed by the agent/workspace tooling the InternalAgentAdapter may use.
RUN apt-get update && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY backend/requirements.txt backend/requirements.txt
RUN pip install --no-cache-dir -r backend/requirements.txt

# Ship the whole repo so every transitively-imported module is present
# (brain_policy, services/, runtimes/, agent/, agents/, router/, …).
COPY . .

EXPOSE 8100
CMD ["uvicorn", "services.hermes_server:app", "--host", "0.0.0.0", "--port", "8100"]
