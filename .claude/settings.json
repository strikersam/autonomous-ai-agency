{
    "extraKnownMarketplaces": {
        "thedotmack": {
            "source": {
                "source": "github",
                "repo": "thedotmack/claude-mem"
            }
        }
    },
    "enabledPlugins": {
        "claude-mem@thedotmack": true
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); cd \"$ROOT\"; .claude/hooks/graphify-refresh --session'"
                    },
                    {
                        "type": "command",
                        "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); cd \"$ROOT\"; .claude/hooks/session-plan-bootstrap --session'"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); cd \"$ROOT\"; .claude/hooks/graphify-refresh --background'"
                    }
                ]
            }
        ]
    }
}
