# ============================================================================
# LLM Relay — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your setup:
#   cp .env.example .env
#
# All variables are optional unless marked (required).
# Setting more provider keys gives the system more fallback options.
# ============================================================================

# ─── Server ────────────────────────────────────────────────────────────────────
# PROXY_PORT=8000              # Port for the API-key-gated Ollama proxy
# PORT=8001                    # Port for the main backend (dashboard, agents, etc.)
# LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR. Use DEBUG during setup.

# ─── Claude Code / Proxy Behaviour ──────────────────────────────────────────
# These are critical for Claude Code users. Must be ≥4096 for code generation.
# PROXY_DEFAULT_MAX_TOKENS=8192
# PROXY_STRIP_THINK_TAGS=true  # Remove <think> blocks from DeepSeek models
# RATE_LIMIT_RPM=60            # Max requests per minute per key
# MODEL_MAP=claude-sonnet-4-6:qwen3-coder:30b,claude-opus-4-6:deepseek-r1:32b,*:qwen3-coder:30b

# ─── Storage ───────────────────────────────────────────────────────────────────
# Set to sqlite for zero-dependency local dev; mongo for production.
STORAGE_BACKEND=sqlite
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=llm_wiki_dashboard
# MONGO_SELECTION_TIMEOUT_MS=2000

# ─── Ollama (local GPU) ───────────────────────────────────────────────────────
# OLLAMA_BASE=http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3-coder:30b
# OLLAMA_MODELS=               # Custom model storage path (Windows: D:\\aipc-models)

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Admin account — created automatically on first boot.
ADMIN_EMAIL=admin@llmrelay.local
ADMIN_PASSWORD=changeme        # SET THIS before exposing the server
# JWT_SECRET=                  # Random on each start if not set; set for production.
# SECRET_KEY=                  # Alias for JWT_SECRET.

# ─── API Keys (for proxy.py) ──────────────────────────────────────────────────
# API_KEYS=your-key-here       # Comma-separated legacy bearer tokens.
# KEYS_FILE=keys.json          # JSON key store (preferred for team use).
# ADMIN_SECRET=                # Required for admin UI.

# ─── Activation ───────────────────────────────────────────────────────────────
# Self-hosters: set to false to skip the activation gate entirely.
# ACTIVATION_REQUIRED=false

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Providers (uncomment and set keys you have)
# Providers are tried in priority order: the first one with a key wins.
# ═══════════════════════════════════════════════════════════════════════════════

# ── NVIDIA NIM - FREE, no GPU required ────────────────────────────────────────
# Get your key free at https://build.nvidia.com/explore/discover
# This is the recommended starting point: zero local hardware, free tier.
# NVIDIA_API_KEY=nvapi-...
# NVidiaApiKey=                # Alternate env name (case-insensitive fallback)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com
# NVIDIA_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b

# ─── Brain provider ────────────────────────────────────────────────────────
# The agent brain (Planner / Executor / Verifier) prefers free cloud providers
# in this order: NVIDIA NIM > Google Gemini > OpenRouter > DeepSeek > Ollama local.
# Paid Anthropic is never auto-selected — even when ANTHROPIC_API_KEY is set,
# a free provider (when configured) wins. Set one of the keys below for the
# most capable free brain; without any of them the brain falls back to local Ollama.
#
# Recommended: NVIDIA NIM (free, 120B Nemotron). Get a free key at
# https://build.nvidia.com/explore/discover (no credit card required for the free tier).


# ── FreeBuff (free-NVIDIA coding agent + Telegram phone control) ───────────────
# See docs/agents.md. FreeBuff pins routing to free NVIDIA NIM models only.
# FREEBUFF_MODELS=nvidia/nemotron-3-super-120b-a12b,qwen/qwen2.5-coder-32b-instruct,meta/llama-3.3-70b-instruct,meta/llama-3.1-8b-instruct,deepseek-ai/deepseek-r1
# FREEBUFF_REPO_URL=https://github.com/owner/repo     # default repo for FreeBuff draft PRs
# FREEBUFF_UNLIMITED=true                              # /freebuff/* routes skip the RPM limiter (default: unlimited)
# FREEBUFF_RATELIMIT_EXEMPT_KEY_IDS=                   # key_ids exempt from RPM limiter everywhere (default: none)

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-v1

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── OpenRouter ────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Together AI ───────────────────────────────────────────────────────────────
# TOGETHER_API_KEY=...
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# ── Hugging Face ──────────────────────────────────────────────────────────────
# HF_TOKEN=hf_...
# HUGGINGFACE_API_TOKEN=       # Alternate env name
# HF_BASE_URL=https://router.huggingface.co
# HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct

# ── Other providers ───────────────────────────────────────────────────────────
# ZHIPU_API_KEY=...
# DASHSCOPE_API_KEY=...
# MINIMAX_API_KEY=...
# GOOGLE_API_KEY=...
# MOONSHOT_API_KEY=...
# EMERGENT_LLM_KEY=...         # Universal key for emergent Anthropic routing

# ── LLM Provider priority ─────────────────────────────────────────────────────
# LLM_PROVIDER=ollama          # Default seeded provider (ollama, nvidia-nim, deepseek)
# INCLUDE_LOCAL_FALLBACK=false # Set true to always try local Ollama as last resort

# ═══════════════════════════════════════════════════════════════════════════════
# Agent Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# AGENT_PLANNER_MODEL=deepseek-r1:32b
# AGENT_EXECUTOR_MODEL=qwen3-coder:30b
# AGENT_VERIFIER_MODEL=deepseek-r1:32b
# AGENT_JUDGE_MODEL=deepseek-r1:32b
# AGENT_WORKSPACE_ROOT=        # Defaults to repo root

# ═══════════════════════════════════════════════════════════════════════════════
# Observability (Langfuse)
# ═══════════════════════════════════════════════════════════════════════════════

# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub Integration
# ═══════════════════════════════════════════════════════════════════════════════

# GITHUB_TOKEN=ghp_...         # Personal access token for agent branches/PRs
# GH_TOKEN=                    # Alternate env name
# GITHUB_CLIENT_ID=            # OAuth App client ID (optional)
# GITHUB_CLIENT_SECRET=        # OAuth App client secret (optional)
# GOOGLE_CLIENT_ID=            # Google OAuth 2.0 client ID (optional)
# GOOGLE_CLIENT_SECRET=        # Google OAuth 2.0 client secret (optional)
# OAUTH_REDIRECT_BASE=         # Public base URL of this server, e.g. https://myserver.com
#                              # Must match the callback URL registered in GitHub/Google OAuth Apps.
#                              # Leave unset for local dev (http://localhost:8001 auto-detected).

# ═══════════════════════════════════════════════════════════════════════════════
# Website Scanner
# ═══════════════════════════════════════════════════════════════════════════════

# SCANNER_HEADLESS_RENDER=auto # auto / off — Playwright headless browser for JS sites
# SCANNER_BUILTWITH_FALLBACK=auto # auto / off — BuiltWith.com fallback

# ═══════════════════════════════════════════════════════════════════════════════
# Shared State (Redis — optional)
# ═══════════════════════════════════════════════════════════════════════════════
# When REDIS_URL is set, provider cooldowns and task-claim locks are backed by
# Redis so they survive process restarts and work across web/worker boundaries.
# Unset → in-memory (default — zero config, single-process only).
# REDIS_URL=redis://localhost:6379/0
# REDIS_KEY_PREFIX=llms:

# ═══════════════════════════════════════════════════════════════════════════════
# Runtime Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# RUNTIME_NEVER_PAID=false
# RUNTIME_REQUIRE_APPROVAL=false
# RUNTIME_MAX_PAID_ESCALATIONS=0
# RUNTIME_DEFAULT=internal_agent

# # Specialist runtimes Hermes/Goose/Aider are now registered BY DEFAULT and become
# # usable automatically when their CLI/sidecar is present (otherwise they report
# # unavailable and the router falls back to internal_agent). Disable all of them
# # at once with RUNTIME_EXTERNAL_DISABLED=true, or individually with the flags below.
# RUNTIME_EXTERNAL_DISABLED=false
# RUNTIME_HERMES_ENABLED=true
# RUNTIME_GOOSE_ENABLED=true
# RUNTIME_AIDER_ENABLED=true
# # Still opt-in (off by default):
# RUNTIME_DOCKER_ENABLED=false
# RUNTIME_OPENCODE_ENABLED=false
# RUNTIME_CLAUDE_CODE_ENABLED=false
# RUNTIME_JCODE_ENABLED=false
# RUNTIME_OPENHANDS_ENABLED=false

# # Free Kimi (Moonshot) web bridge — gives agents a capable model with NO paid API
# # key. Classified as a free provider so the routing policy never refuses it as
# # "paid escalation". Point KIMI_BRIDGE_URL at any OpenAI-compatible bridge/gateway
# # (e.g. a small Playwright/Browserbase shim that drives kimi.com).
# KIMI_BRIDGE_ENABLED=false
# KIMI_BRIDGE_URL=http://localhost:8011/v1
# KIMI_BRIDGE_MODEL=kimi-k2.6
# KIMI_BRIDGE_TOKEN=
# KIMI_BRIDGE_MODE=endpoint        # endpoint | browser
# KIMI_BRIDGE_BROWSER=false        # must be true to allow KIMI_BRIDGE_MODE=browser
# KIMI_BRIDGE_PRIORITY=5

# # Agent auto-PR: when an agent run auto-commits with a target repo, also push an
# # agent/<task> branch and open a PR (never to a protected branch). Opt-in.
# AGENT_AUTO_PR_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# Infrastructure Cost Tracking
# ═══════════════════════════════════════════════════════════════════════════════

# INFRA_GPU_ACTIVE_WATTS=150
# INFRA_GPU_IDLE_WATTS=20
# INFRA_SYSTEM_WATTS=50
# INFRA_ELECTRICITY_USD_KWH=0.12
# INFRA_HARDWARE_COST_USD=2000
# INFRA_AMORTIZATION_MONTHS=36

# ═══════════════════════════════════════════════════════════════════════════════
# Telegram Bot (optional)
# ═══════════════════════════════════════════════════════════════════════════════

# TELEGRAM_BOT_TOKEN=...
#
# Single-operator shortcut: set TELEGRAM_CHAT_ID to your numeric Telegram user
# ID (from @userinfobot) and skip TELEGRAM_ALLOWED_USER_IDS/ADMIN_USER_IDS/
# NOTIFY_CHAT_IDS entirely — it is used as a fallback for ALL of them (bot
# auth AND the Telegram approval-gate / notification pushes, Autonomy Charter
# G1). Set the more specific vars below only if you need a different value
# per purpose (e.g. notifications to a group chat, admins != allowed users).
# TELEGRAM_CHAT_ID=...
# TELEGRAM_ALLOWED_USER_IDS=...
# TELEGRAM_ADMIN_USER_IDS=...
# TELEGRAM_NOTIFY_CHAT_IDS=...
# TELEGRAM_PROXY_API_KEY=...

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend
# ═══════════════════════════════════════════════════════════════════════════════

# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=*               # Comma-separated allowed origins
