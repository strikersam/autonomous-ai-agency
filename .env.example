# ═══════════════════════════════════════════════════════════════════════════════

# INFRA_GPU_ACTIVE_WATTS=150
# INFRA_GPU_IDLE_WATTS=20
# INFRA_SYSTEM_WATTS=50
# INFRA_ELECTRICITY_USD_KWH=0.12
# INFRA_HARDWARE_COST_USD=2000
# INFRA_AMORTIZATION_MONTHS=36

# ═══════════════════════════════════════════════════════════════════════════════
# Telegram Bot (optional)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Minimal setup for a single-operator control plane (the most common case):
#
#   1. Talk to @BotFather on Telegram, run /newbot, copy the token into
#      TELEGRAM_BOT_TOKEN below. Tokens contain NO whitespace — paste carefully.
#   2. Talk to @userinfobot and copy your numeric user ID (e.g. ``8120976``,
#      NOT your @username). Put it in TELEGRAM_CHAT_ID below.
#   3. Restart the bot. Send /diag to it; it must answer with token-masked,
#      allow-listed admin/non-admin IDs and the resolved chat-id fallback.
#      If /diag answers "Empty allowlist" the bot is silently dropping every
#      message — re-check step 2 (must be the NUMERIC id, not @name).
#   4. Send /help to list every command. /status, /models, /cost are admin-free;
#      /redirect, /paste, /agent, /start|stop|restart, /freebuff, /keylist are
#      admin-only.
#
# Single-operator shortcut: setting TELEGRAM_CHAT_ID alone is sufficient for
# BOTH auth (allowed + admin) AND notification delivery — do NOT also set
# TELEGRAM_ALLOWED_USER_IDS / TELEGRAM_ADMIN_USER_IDS unless you want different
# IDs per purpose (e.g. group chat for notifications, two operators for auth).
# (See Autonomy Charter G1 in docs/autonomy/AUTONOMY_CHARTER.md for context.)
#
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# TELEGRAM_ALLOWED_USER_IDS=...   # Optional — defaults to TELEGRAM_CHAT_ID.
# TELEGRAM_ADMIN_USER_IDS=...     # Optional — defaults to TELEGRAM_CHAT_ID.
# TELEGRAM_NOTIFY_CHAT_IDS=...    # Optional — group chat for digest/approval pings.
# TELEGRAM_PROXY_API_KEY=...      # Optional — proxy bearer key the bot uses
#                                 #   when calling the local LLM proxy.
#                                 #   Defaults to ``sk-qwen-<host>``-style key
#                                 #   from API_KEYS; only set explicitly if
#                                 #   the bot needs a dedicated key.
#
# ─── Mutating Telegram control (N5 — /setbrain + /merge) ─────────────────
# The /setbrain <provider> and /merge <pr> commands mutate the brain config
# and master branch, so they require a backend service token (NOT the
# TELEGRAM_BOT_TOKEN — that's only for talking to the Telegram API). Set
# SERVICE_TOKEN to the SAME high-entropy value in BOTH the backend env
# (so it can verify the header) AND the bot env (so it can send the header).
# Generate with: python -c "import secrets; print('st_' + secrets.token_urlsafe(32))"
# The backend hashes it with SHA-256 + hmac.compare_digest; the plaintext
# is never cached beyond the comparison call site. See services/service_token.py.
#
# SERVICE_TOKEN=...                # Required for /setbrain + /merge to work.
#                                  # Set on BOTH the backend AND the Telegram bot.

# ─── GitHub Actions post-merge notification ─────────────────────────────
# For the automated post-merge Telegram notification workflow
# (`.github/workflows/post-merge-telegram-notify.yml`) to fire when a PR is
# merged to master, you MUST also add `TELEGRAM_BOT_TOKEN` and
# `TELEGRAM_CHAT_ID` as GitHub Actions Repository Secrets — Settings →
# Secrets and variables → Actions. The workflow validates presence and fails
# fast with a `::error::` annotation if either is missing.
#
# ── Multiple-poller guard (issue #656) ─────────────────────────────────────────
# Telegram allows ONE long-poller per bot token. If your web service AND a
# dedicated worker both long-poll the same token you get a storm of 409/
# 429 errors. Set TELEGRAM_POLLER_DISABLED=true on whichever process should
# NOT poll (typically the web service, leaving the dedicated worker to own
# the long-poll). When set, the bot keeps the process alive (does not exit)
# so Render doesn't churn the service.
# TELEGRAM_POLLER_DISABLED=false
#
# ── E2B Firecracker micro-VM sandbox (roadmap ★5) ─────────────────────────────
# Routes agent code edits, command runs, and git operations into isolated E2B
# sandboxes (boot ≈150 ms, no local Docker required). Requires explicit opt-in:
# set E2B_ENABLED=true AND E2B_API_KEY to activate. Setting the key alone is
# NOT enough — e2b_enabled() requires the explicit flag.
# Get a key at https://e2b.dev. When E2B is unavailable, the agent falls back
# to the existing local git worktree path with zero behaviour change.
# E2B_API_KEY=e2b_...
# E2B_ENABLED=true               # REQUIRED to activate E2B (key alone is not enough)
# RUNTIME_E2B_ENABLED=           # alternative opt-in flag (parity w/ other runtimes)
# E2B_TEMPLATE=base              # sandbox template id ('base' ships Python+git)
# E2B_TIMEOUT_SEC=300            # sandbox lifetime; clamped to [30, 1800]
# E2B_SANDBOX_METADATA=          # optional key=value,key=value metadata
# AGENT_SANDBOX_MODE=e2b         # canonical roadmap ★5 kill-switch (alt activation)
#
# ── FreeBuff on Telegram ─────────────────────────────────────────────────────
# Runs the FreeBuff (free-NVIDIA coding agent) path INSIDE the bot's process
# instead of via the proxy — single self-contained 24x7 worker.
# FREEBUFF_EMBEDDED=true
# FREEBUFF_REPO_URL=https://github.com/strikersam/autonomous-ai-agency
# FREEBUFF_BASE_BRANCH=feature/daily-digest-and-inbound-routing
# FREEBUFF_MAX_STEPS=10
# GITHUB_TOKEN=ghp_...   # Required for FREEBUFF_EMBEDDED=true to push/PR.

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend
# ═══════════════════════════════════════════════════════════════════════════════

# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=*               # Comma-s
# ── OpenClaw Gateway (iOS control of the agency) ─────────────────────────────
# OpenClaw (https://openclaw.ai) is a self-hosted Gateway + native iOS/Android
# app. The Gateway holds the "brain"; phones pair via QR. This service runs
# the Gateway 24×7, pointed at the agency's existing proxy + MCP server so the
# iOS app can drive agency workflows, not just chat.
#
# PERSISTENT DISK REQUIRED: ~/.openclaw holds pairing tokens. On a free/
# ephemeral disk, every redeploy un-pairs the phone.
#
# SECURITY: Do NOT expose port 18789 directly. The Gateway binds to $PORT and
# Render's HTTPS proxy handles TLS + OpenClaw's device-pairing/token auth.
# OPENCLAW_PORT=18789              # Render injects $PORT; this is the internal default
# OPENCLAW_AGENT_BASE_URL=https://local-llm-server.onrender.com/v1
# OPENCLAW_AGENT_API_KEY=...       # Agency API key (sync:false on Render)
# OPENCLAW_AGENT_MODEL=meta/llama-3.3-70b-instruct
# OPENCLAW_MCP_BASE_URL=https://local-llm-server.onrender.com/mcp-internal
# OPENCLAW_MCP_SECRET_TOKEN=...    # Must match MCP_SECRET_TOKEN on the web service
# OPENCLAW_PAIRING_TOKEN=...       # openssl rand -hex 32 — gates who can pair

# ── Additional LLM providers for brain failover ──────────────────────────────
# These are automatically picked up by the brain failover system. When the
# primary provider (NVIDIA) is rate-limited (429) or dead (410), the system
# fails over to the next healthy provider in priority order.
#
# Z.ai (GLM international) — free, same models as Zhipu but international endpoint
# ZAI_API_KEY=...                   # Get at https://z.ai
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
#
# Aerolink (Claude gateway) — paid, $10/week, provides Claude models
# AEROLINK_API_KEY=...              # Get at https://aerolink.lat
# AEROLINK_BASE_URL=https://capi.aerolink.lat/v1
# --- Local qwen2.5-coder-7b brain (cross-machine toggle) ---
# The cloud admin SPA exposes a toggle on the Providers page that writes to
# /api/local-brain/state via SERVICE_TOKEN. A daemon on this box (scripts/local_controller.py)
# polls every LOCAL_BRAIN_INTERVAL seconds and (de)commissions the local llama-server.exe
# serving GLM-5.2. With the toggle ON, the brain resolver routes all brain calls through
# port 8072 on this machine. With it OFF, the brain falls through to the cloud recommended
# chain (NVIDIA -> Cerebras -> Groq).
# Install: scripts/setup_local_controller.ps1 registers a Task Scheduler entry with
# AtStartup + AtLogon triggers so the toggle survives reboots.
# REQUIRED for the daemon - SAME value as the cloud backend SERVICE_TOKEN.  If you rotate
# the cloud token you MUST also update this env var on the local machine (and re-run
# setup_local_controller.ps1) or every heartbeat is silently 503-rejected.
# LOCAL_BRAIN_TOKEN=replace-with-the-render-service-token-min-32-chars
# AGENCY_URL=https://local-llm-server.strikersam.workers.dev
# LOCAL_BRAIN_HTTP_PORT=8072
# LOCAL_BRAIN_INTERVAL=30
# LOCAL_BRAIN_START_TIMEOUT=240
# LOCAL_BRAIN_BIN=D:\hfkld-qg7ky\local-models\llama.cppuildin\Release\llama-server.exe
# LOCAL_BRAIN_MODEL_PATH=D:\hfkld-qg7ky\local-models\gguf\qwen2.5-coder-7b-instruct-q4_k_m.gguf  # 4.36 GB Q4_K_M; fits 8 GB iGPU w/ CTX=4096 (~4 GB KV cache + 4.36 GB weights = 8 GB total).
# LOCAL_BRAIN_MODEL_ID=qwen2.5-coder-7b         # alias llama-server registers at /v1/models
# LOCAL_BRAIN_CTX=4096                           # ~4 GB KV cache + 4.36 GB weights = 8 GB total; matches the 8 GB iGPU budget
# LOCAL_BRAIN_THREADS=8
# LOCAL_BRAIN_GPU_LAYERS=99
# NOTE: scripts/local_controller.py --once will KILL this server if AGENCY_URL's /api/local-brain/state shows desired=off.
# Either (a) flip the Cloudflare Providers-page local-brain toggle ON FIRST, or
# (b) set LOCAL_BRAIN_TOKEN for a stand-alone local-only launch (no cloud-managed toggle).
# Pair with BRAIN_PREFERENCE=local-brain (above) to make the agency brain route through this 127.0.0.1:8072 endpoint (packages/ai/brain.py env-shim).
