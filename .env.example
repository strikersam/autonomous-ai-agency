# ============================================================================
# LLM Relay — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your setup:
#   cp .env.example .env
#
# All variables are optional unless marked (required).
# Setting more provider keys gives the system more fallback options.
# ============================================================================

# ─── Server ────────────────────────────────────────────────────────────────────
# PROXY_PORT=8000              # Port for the API-key-gated Ollama proxy
# PORT=8001                    # Port for the main backend (dashboard, agents, etc.)
# LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR. Use DEBUG during setup.

# ─── Claude Code / Proxy Behaviour ──────────────────────────────────────────
# These are critical for Claude Code users. Must be ≥4096 for code generation.
# PROXY_DEFAULT_MAX_TOKENS=8192
# PROXY_STRIP_THINK_TAGS=true  # Remove <think> blocks from DeepSeek models
# RATE_LIMIT_RPM=60            # Max requests per minute per key
# MODEL_MAP=claude-sonnet-4-6:qwen3-coder:30b,claude-opus-4-6:deepseek-r1:32b,*:qwen3-coder:30b

# ─── Storage ───────────────────────────────────────────────────────────────────
# Set to sqlite for zero-dependency local dev; mongo for production.
STORAGE_BACKEND=sqlite
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=llm_wiki_dashboard
# MONGO_SELECTION_TIMEOUT_MS=2000

# ─── Ollama (local GPU) ───────────────────────────────────────────────────────
# OLLAMA_BASE=http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3-coder:30b
# OLLAMA_MODELS=               # Custom model storage path (Windows: D:\\aipc-models)

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Admin account — created automatically on first boot.
ADMIN_EMAIL=admin@llmrelay.local
ADMIN_PASSWORD=changeme        # SET THIS before exposing the server
# JWT_SECRET=                  # Random on each start if not set; set for production.
# SECRET_KEY=                  # Alias for JWT_SECRET.

# ─── API Keys (for proxy.py) ──────────────────────────────────────────────────
# API_KEYS=your-key-here       # Comma-separated legacy bearer tokens.
# KEYS_FILE=keys.json          # JSON key store (preferred for team use).
# ADMIN_SECRET=                # Required for admin UI.

# ─── Activation ───────────────────────────────────────────────────────────────
# Self-hosters: set to false to skip the activation gate entirely.
# ACTIVATION_REQUIRED=false

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Providers (uncomment and set keys you have)
# Providers are tried in priority order: the first one with a key wins.
# ═══════════════════════════════════════════════════════════════════════════════

# ── NVIDIA NIM - FREE, no GPU required ────────────────────────────────────────
# Get your key free at https://build.nvidia.com/explore/discover
# This is the recommended starting point: zero local hardware, free tier.
# NVIDIA_API_KEY=nvapi-...
# NVidiaApiKey=                # Alternate env name (case-insensitive fallback)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com
# Powerful free NIM brain (no rate limits, cloud-hosted) — Nemotron-3 super
# 120B-a12b MoE: ~12B active params/token, so it's fast *and* a reasoning model
# (vs the 550B "ultra" which activates ~55B/call and is several times slower):
# https://build.nvidia.com/nvidia/llama-3.3-nemotron-super-49b-v1
# NVIDIA_DEFAULT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# ── Brain policy (free-first) ─────────────────────────────────────────────────
# The agent brain prefers free cloud providers (NVIDIA NIM first). Set
# NVIDIA_API_KEY above and the brain resolves to the free NVIDIA model with no
# further config. The brain NEVER silently uses paid Anthropic (issue #656):
# set ALLOW_PAID_BRAIN=true to permit paid Anthropic as a last resort when no
# free provider is configured. Default is free-only.
# ALLOW_PAID_BRAIN=false

# ─── Brain provider ────────────────────────────────────────────────────────
# The agent brain (Planner / Executor / Verifier) prefers free cloud providers
# in this order: NVIDIA NIM > Google Gemini > OpenRouter > DeepSeek > Ollama local.
# Paid Anthropic is never auto-selected — even when ANTHROPIC_API_KEY is set,
# a free provider (when configured) wins. Set one of the keys below for the
# most capable free brain; without any of them the brain falls back to local Ollama.
#
# Recommended: NVIDIA NIM (free Nemotron, e.g. llama-3.3-nemotron-super-49b-v1 — see
# the NVIDIA_DEFAULT_MODEL note above). Get a free key at
# https://build.nvidia.com/explore/discover (no credit card required for the free tier).


# ── FreeBuff (free-NVIDIA coding agent + Telegram phone control) ───────────────
# See docs/agents.md. FreeBuff pins routing to free NVIDIA NIM models only.
# FREEBUFF_MODELS=nvidia/llama-3.3-nemotron-super-49b-v1,qwen/qwen2.5-coder-32b-instruct,meta/llama-3.3-70b-instruct,meta/llama-3.1-8b-instruct,deepseek-ai/deepseek-r1
# FREEBUFF_REPO_URL=https://github.com/owner/repo     # default repo for FreeBuff draft PRs
# FREEBUFF_UNLIMITED=true                              # /freebuff/* routes skip the RPM limiter (default: unlimited)
# FREEBUFF_RATELIMIT_EXEMPT_KEY_IDS=                   # key_ids exempt from RPM limiter everywhere (default: none)

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-v1

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── OpenRouter ────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Together AI ───────────────────────────────────────────────────────────────
# TOGETHER_API_KEY=...
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# ── Hugging Face ──────────────────────────────────────────────────────────────
# HF_TOKEN=hf_...
# HUGGINGFACE_API_TOKEN=       # Alternate env name
# HF_BASE_URL=https://router.huggingface.co
# HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct

# ── Other providers ───────────────────────────────────────────────────────────
# ZHIPU_API_KEY=...
# DASHSCOPE_API_KEY=...
# MINIMAX_API_KEY=...
# GOOGLE_API_KEY=...
# MOONSHOT_API_KEY=...
# EMERGENT_LLM_KEY=...         # Universal key for emergent Anthropic routing

# ── LLM Provider priority ─────────────────────────────────────────────────────
# LLM_PROVIDER=ollama          # Default seeded provider (ollama, nvidia-nim, deepseek)
# INCLUDE_LOCAL_FALLBACK=false # Set true to always try local Ollama as last resort

# ═══════════════════════════════════════════════════════════════════════════════
# Agent Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# AGENT_PLANNER_MODEL=deepseek-r1:32b
# AGENT_EXECUTOR_MODEL=qwen3-coder:30b
# AGENT_VERIFIER_MODEL=deepseek-r1:32b
# AGENT_JUDGE_MODEL=deepseek-r1:32b
# AGENT_WORKSPACE_ROOT=        # Defaults to repo root

# ── Per-company trend scoping (Autonomy Charter G4) ──────────────────────────
# TrendWatcher scopes each discovered trend to onboarded companies whose detected
# stack matches, creating one task per relevant company (research = autonomous,
# code/infra change = Telegram-gated). Min per-company relevance (0..1) to act:
# TREND_COMPANY_MIN_SCORE=0.5
# Set to false to disable per-company fan-out (platform-level trends only):
# TREND_COMPANY_SCOPING_ENABLED=true

# ── Autonomous loops (the self-running agency) ───────────────────────────────
# These background engines turn signals into work and are started by
# services/background.start_background_services (web lifespan + worker_main).
# All default ON; set any to false to disable that loop:
#   AGENCY_CEO_ENABLED         — proactive 24×7 CEO work generation
#   AGENCY_IMPROVEMENT_ENABLED — TODO/coverage/perf signals → fix jobs (Loop 2)
#   AGENCY_SELF_HEAL_ENABLED   — failure signals → verified fixes (Loop 1 / G2)
#   AGENCY_LOG_MONITOR_ENABLED — runtime ERROR/CRITICAL logs → auto fix tasks
#   AGENCY_TREND_WATCH_ENABLED — periodic trend fetch → per-company scoping (G4)
# AGENCY_IMPROVEMENT_ENABLED=true
# AGENCY_SELF_HEAL_ENABLED=true
# AGENCY_LOG_MONITOR_ENABLED=true
# AGENCY_TREND_WATCH_ENABLED=true
# TREND_WATCH_POLL_SEC=3600     # how often the trend poller checks "due for fetch"
# TREND_WATCH_WARMUP_SEC=60     # delay before the first trend fetch after boot
# LogMonitor storm guard: max auto-created fix tasks per rolling hour (0=off).
# Operational/transient errors (timeouts, provider 5xx, rate limits) are always
# skipped — only real code-bug errors auto-create fix tasks.
# LOG_MONITOR_MAX_TASKS_PER_HOUR=6

# ─── Performance / throughput (free cloud brain) ─────────────────────────────
# A full agent run on a FREE brain makes several sequential LLM calls
# (plan→execute→verify→judge) and can be slow. If you see "Execution timed out
# after 150s" / "blocked after N dispatch attempts" and a sluggish board:
#   • Give runs room to COMPLETE instead of failing+retrying (default now 300s):
# TASK_EXECUTION_TIMEOUT_SEC=300
#   • The default brain is already the fast 120B-a12b MoE (~12B active/call). If
#     it's ever unavailable, the dense 49B is a fast fallback; the 550B "ultra"
#     (~55B active) is the most capable but several times slower per call:
# NVIDIA_DEFAULT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1   # default (fast reasoning MoE)
# NVIDIA_DEFAULT_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1   # fallback (fast dense)
#   • Lower concurrency if the free tier rate-limits you:
# TASK_DISPATCH_CONCURRENCY=3
#   • Emergency: pause the log-driven self-heal loop entirely:
# AGENCY_LOG_MONITOR_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# Observability (Langfuse)
# ═══════════════════════════════════════════════════════════════════════════════

# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub Integration
# ═══════════════════════════════════════════════════════════════════════════════

# GITHUB_TOKEN=ghp_...         # Personal access token for agent branches/PRs
# GH_TOKEN=                    # Alternate env name
# GITHUB_WEBHOOK_SECRET=       # HMAC secret for POST /api/webhooks/github (issue→task
#                              # intake, Autonomy Charter G3). Unset = endpoint disabled (503).
# ISSUE_INTAKE_LABEL=autonomy:intake  # Only issues with this label become tasks.
# REPO_ALLOW_DIRECT_PUSH=false # RepoConnection delivery policy (Autonomy Charter G5):
#                              # when a repo's default branch is unprotected, only emit
#                              # 'direct_push' if this is true; otherwise the safe default
#                              # is 'pr_required'. Protected/uncertain is always pr_required.
# GITHUB_CLIENT_ID=            # OAuth App client ID (optional)
# GITHUB_CLIENT_SECRET=        # OAuth App client secret (optional)
# GOOGLE_CLIENT_ID=            # Google OAuth 2.0 client ID (optional)
# GOOGLE_CLIENT_SECRET=        # Google OAuth 2.0 client secret (optional)
# OAUTH_REDIRECT_BASE=         # Public base URL of this server, e.g. https://myserver.com
#                              # Must match the callback URL registered in GitHub/Google OAuth Apps.
#                              # Leave unset for local dev (http://localhost:8001 auto-detected).

# ═══════════════════════════════════════════════════════════════════════════════
# Website Scanner
# ═══════════════════════════════════════════════════════════════════════════════

# SCANNER_HEADLESS_RENDER=auto # auto / off — Playwright headless browser for JS sites
# SCANNER_BUILTWITH_FALLBACK=auto # auto / off — BuiltWith.com fallback

# ═══════════════════════════════════════════════════════════════════════════════
# Shared State (Redis — optional)
# ═══════════════════════════════════════════════════════════════════════════════
# When REDIS_URL is set, provider cooldowns and task-claim locks are backed by
# Redis so they survive process restarts and work across web/worker boundaries.
# Unset → in-memory (default — zero config, single-process only).
# REDIS_URL=redis://localhost:6379/0
# REDIS_KEY_PREFIX=llms:

# ═══════════════════════════════════════════════════════════════════════════════
# Runtime Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# RUNTIME_NEVER_PAID=false
# RUNTIME_REQUIRE_APPROVAL=false
# RUNTIME_MAX_PAID_ESCALATIONS=0
# RUNTIME_DEFAULT=internal_agent

# # Specialist runtimes Hermes/Goose/Aider are now registered BY DEFAULT and become
# # usable automatically when their CLI/sidecar is present (otherwise they report
# # unavailable and the router falls back to internal_agent). Disable all of them
# # at once with RUNTIME_EXTERNAL_DISABLED=true, or individually with the flags below.
# RUNTIME_EXTERNAL_DISABLED=false
# RUNTIME_HERMES_ENABLED=true
# RUNTIME_GOOSE_ENABLED=true
# RUNTIME_AIDER_ENABLED=true
# # Still opt-in (off by default):
# RUNTIME_DOCKER_ENABLED=false
# RUNTIME_OPENCODE_ENABLED=false
# RUNTIME_CLAUDE_CODE_ENABLED=false
# RUNTIME_JCODE_ENABLED=false
# RUNTIME_OPENHANDS_ENABLED=false

# # Free Kimi (Moonshot) web bridge — gives agents a capable model with NO paid API
# # key. Classified as a free provider so the routing policy never refuses it as
# # "paid escalation". Point KIMI_BRIDGE_URL at any OpenAI-compatible bridge/gateway
# # (e.g. a small Playwright/Browserbase shim that drives kimi.com).
# KIMI_BRIDGE_ENABLED=false
# KIMI_BRIDGE_URL=http://localhost:8011/v1
# KIMI_BRIDGE_MODEL=kimi-k2.6
# KIMI_BRIDGE_TOKEN=
# KIMI_BRIDGE_MODE=endpoint        # endpoint | browser
# KIMI_BRIDGE_BROWSER=false        # must be true to allow KIMI_BRIDGE_MODE=browser
# KIMI_BRIDGE_PRIORITY=5

# # Agent auto-PR: when an agent run auto-commits with a target repo, also push an
# # agent/<task> branch and open a PR (never to a protected branch). Opt-in.
# AGENT_AUTO_PR_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# Infrastructure Cost Tracking
# ═══════════════════════════════════════════════════════════════════════════════

# INFRA_GPU_ACTIVE_WATTS=150
# INFRA_GPU_IDLE_WATTS=20
# INFRA_SYSTEM_WATTS=50
# INFRA_ELECTRICITY_USD_KWH=0.12
# INFRA_HARDWARE_COST_USD=2000
# INFRA_AMORTIZATION_MONTHS=36

# ═══════════════════════════════════════════════════════════════════════════════
# Telegram Bot (optional)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Minimal setup for a single-operator control plane (the most common case):
#
#   1. Talk to @BotFather on Telegram, run /newbot, copy the token into
#      TELEGRAM_BOT_TOKEN below. Tokens contain NO whitespace — paste carefully.
#   2. Talk to @userinfobot and copy your numeric user ID (e.g. ``8120976``,
#      NOT your @username). Put it in TELEGRAM_CHAT_ID below.
#   3. Restart the bot. Send /diag to it; it must answer with token-masked,
#      allow-listed admin/non-admin IDs and the resolved chat-id fallback.
#      If /diag answers "Empty allowlist" the bot is silently dropping every
#      message — re-check step 2 (must be the NUMERIC id, not @name).
#   4. Send /help to list every command. /status, /models, /cost are admin-free;
#      /redirect, /paste, /agent, /start|stop|restart, /freebuff, /keylist are
#      admin-only.
#
# Single-operator shortcut: setting TELEGRAM_CHAT_ID alone is sufficient for
# BOTH auth (allowed + admin) AND notification delivery — do NOT also set
# TELEGRAM_ALLOWED_USER_IDS / TELEGRAM_ADMIN_USER_IDS unless you want different
# IDs per purpose (e.g. group chat for notifications, two operators for auth).
# (See Autonomy Charter G1 in docs/autonomy/AUTONOMY_CHARTER.md for context.)
#
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# TELEGRAM_ALLOWED_USER_IDS=...   # Optional — defaults to TELEGRAM_CHAT_ID.
# TELEGRAM_ADMIN_USER_IDS=...     # Optional — defaults to TELEGRAM_CHAT_ID.
# TELEGRAM_NOTIFY_CHAT_IDS=...    # Optional — group chat for digest/approval pings.
# TELEGRAM_PROXY_API_KEY=...      # Optional — proxy bearer key the bot uses
#                                 #   when calling the local LLM proxy.
#                                 #   Defaults to ``sk-qwen-<host>``-style key
#                                 #   from API_KEYS; only set explicitly if
#                                 #   the bot needs a dedicated key.

# ─── GitHub Actions post-merge notification ─────────────────────────────
# For the automated post-merge Telegram notification workflow
# (`.github/workflows/post-merge-telegram-notify.yml`) to fire when a PR is
# merged to master, you MUST also add `TELEGRAM_BOT_TOKEN` and
# `TELEGRAM_CHAT_ID` as GitHub Actions Repository Secrets — Settings →
# Secrets and variables → Actions. The workflow validates presence and fails
# fast with a `::error::` annotation if either is missing.
#
# ── Multiple-poller guard (issue #656) ─────────────────────────────────────────
# Telegram allows ONE long-poller per bot token. If your web service AND a
# dedicated worker both long-poll the same token you get a storm of 409/
# 429 errors. Set TELEGRAM_POLLER_DISABLED=true on whichever process should
# NOT poll (typically the web service, leaving the dedicated worker to own
# the long-poll). When set, the bot keeps the process alive (does not exit)
# so Render doesn't churn the service.
# TELEGRAM_POLLER_DISABLED=false
#
# ── FreeBuff on Telegram ─────────────────────────────────────────────────────
# Runs the FreeBuff (free-NVIDIA coding agent) path INSIDE the bot's process
# instead of via the proxy — single self-contained 24x7 worker.
# FREEBUFF_EMBEDDED=true
# FREEBUFF_REPO_URL=git@github.com:strikersam/local-llm-server.git
# FREEBUFF_BASE_BRANCH=feature/daily-digest-and-inbound-routing
# FREEBUFF_MAX_STEPS=10
# GITHUB_TOKEN=ghp_...   # Required for FREEBUFF_EMBEDDED=true to push/PR.

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend
# ═══════════════════════════════════════════════════════════════════════════════

# FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=*               # Comma-separated allowed origins
